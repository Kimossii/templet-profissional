  <entry>
    <title>Oesophagogastric surgery will be featured in a 120-minute session</title>
    <link rel="alternate" href="https://www.apcir.pt/oesophagogastric-session-120-minutes" />
    <link rel="enclosure" type="image/png" href="https://irp.cdn-website.com/443a37e1/dms3rep/multi/Oesophagogastric-Session---120-Minutes-4.png" length="658325" />
